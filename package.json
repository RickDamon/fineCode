{
  "name": "fine-code",
  "version": "0.1.0",
  "description": "A minimal, model-agnostic coding agent inspired by Claude Code's harness philosophy",
  "type": "module",
  "bin": {
    "fine": "./dist/cli.js",
    "fine-code": "./dist/cli.js"
  },
  "main": "./dist/cli.js",
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "engines": {
    "node": ">=18.0.0"
  },
  "scripts": {
    "build": "tsc && node -e \"import('fs').then(fs=>fs.chmodSync('dist/cli.js',0o755))\"",
    "dev": "tsx src/cli.tsx",
    "start": "node dist/cli.js",
    "prepare": "npm run build",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "cli",
    "ai",
    "agent",
    "coding-agent",
    "llm",
    "claude",
    "openai",
    "deepseek",
    "harness"
  ],
  "license": "MIT",
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "chalk": "^5.3.0",
    "commander": "^12.1.0",
    "ink": "^5.0.1",
    "ink-spinner": "^5.0.0",
    "ink-text-input": "^6.0.0",
    "openai": "^4.67.0",
    "react": "^18.3.1",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "@types/react": "^18.3.0",
    "tsx": "^4.19.0",
    "typescript": "^5.6.0"
  }
}
